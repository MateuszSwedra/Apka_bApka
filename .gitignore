# ==========================================
# Frontend (React Native / Expo)
# ==========================================
.expo/
.expo-shared/
web-build/
expo-env.d.ts
# Jeśli używamy Expo "Managed Workflow" (Continuous Native Generation), 
# foldery ios/ i android/ są generowane w locie i ich nie wersjonujemy. 
# Jeśli planujesz robić modyfikacje w kodzie natywnym, zakomentuj te dwie linie:
ios/
android/
# Pliki binarne i klucze (Android/iOS)
*.apk
*.aab
*.ipa
*.jks
*.keystore
*.p12
*.mobileprovision
*.orig.*

